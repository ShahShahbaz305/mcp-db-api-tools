# =============================================================================
# MCP Cheatsheet - Environment Template
# =============================================================================
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Inspector (Read-Only MySQL)
# -----------------------------------------------------------------------------
# Option A: Connection string
# DB_CONNECTION_STRING=mysql://username:password@host:3306/database_name

# Option B: Individual parameters
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_NAME=your_database

# -----------------------------------------------------------------------------
# API Runner
# -----------------------------------------------------------------------------
API_BASE_URL=http://localhost:3000
API_AUTH_TOKEN=your_jwt_or_bearer_token

# -----------------------------------------------------------------------------
# Debug (optional)
# -----------------------------------------------------------------------------
# MCP_DEBUG=0
# Set to 0 to disable stderr logging
