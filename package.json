  "bugs": {
    "url": "https://github.com/ShahShahbaz305/mcp-db-api-tools/issues"
  },
  "homepage": "https://github.com/ShahShahbaz305/mcp-db-api-tools#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
